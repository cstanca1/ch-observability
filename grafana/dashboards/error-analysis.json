      "targets": [
        {
          "refId": "A",
          "queryType": "sql",
          "format": 1,
          "rawSql": "SELECT service, countIf(level = 'ERROR') AS errors FROM logs GROUP BY service ORDER BY errors DESC"
        }
      ],
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": {}, "overrides": [] }
