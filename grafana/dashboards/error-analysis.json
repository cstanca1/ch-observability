    {
      "id": 2,
      "type": "table",
      "title": "Error Status Codes",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "queryType": "sql",
          "format": 1,
          "rawSql": "SELECT status_code, count() AS total FROM logs WHERE level = 'ERROR' GROUP BY status_code ORDER BY total DESC"
        }
      ],
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Top Error Combinations",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "queryType": "sql",
          "format": 1,
          "rawSql": "SELECT service, incident_mode, status_code, count() AS total_errors FROM logs WHERE level = 'ERROR' GROUP BY service, incident_mode, status_code ORDER BY total_errors DESC LIMIT 20"
