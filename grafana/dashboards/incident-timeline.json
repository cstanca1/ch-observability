    {
      "id": 1,
      "type": "table",
      "title": "Errors per Minute by Service",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "queryType": "sql",
          "format": 1,
          "rawSql": "SELECT toStartOfMinute(ts) AS minute, service, countIf(level = 'ERROR') AS errors FROM logs GROUP BY minute, service ORDER BY minute DESC, service"
        }
      ],
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Average Latency per Minute by Service",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "queryType": "sql",
          "format": 1,
          "rawSql": "SELECT toStartOfMinute(ts) AS minute, service, round(avg(latency_ms), 2) AS avg_latency_ms FROM logs GROUP BY minute, service ORDER BY minute DESC, service"
        }
      ],
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ],
