  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Events",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "queryType": "sql",
          "format": 1,
          "rawSql": "SELECT count() AS total_events FROM logs"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Average Latency (ms)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "queryType": "sql",
          "format": 1,
          "rawSql": "SELECT round(avg(latency_ms), 2) AS avg_latency_ms FROM logs"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Errors",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "queryType": "sql",
          "format": 1,
          "rawSql": "SELECT countIf(level = 'ERROR') AS total_errors FROM logs"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Events by Service",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "queryType": "sql",
          "format": 1,
          "rawSql": "SELECT service, count() AS events FROM logs GROUP BY service ORDER BY events DESC"
        }
      ],
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Latency by Service",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "targets": [
        {
          "refId": "A",
          "queryType": "sql",
          "format": 1,
          "rawSql": "SELECT service, round(avg(latency_ms), 2) AS avg_latency_ms, round(quantile(0.95)(latency_ms), 2) AS p95_latency_ms FROM logs GROUP BY service ORDER BY avg_latency_ms DESC"
        }
      ],
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ],
